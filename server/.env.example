PORT=3001
CLIENT_ORIGIN=*
NODE_ENV=development

# PostgreSQL is free locally. Install PostgreSQL, create a database, then set this.
# Example local URL:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/voidsector

# Set to true only for hosted PostgreSQL providers that require SSL.
DATABASE_SSL=false

# Local/staging load test only. Never enable this on the public production server.
LOAD_TEST_ENABLED=false
# Required when LOAD_TEST_ENABLED=true. Use at least 16 random characters.
LOAD_TEST_SECRET=

# Production requirements:
# NODE_ENV=production
# CLIENT_ORIGIN=https://game.example.com
# DATABASE_URL=postgres://user:password@host:5432/voidsector
